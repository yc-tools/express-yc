{
  "name": "express-yc",
  "version": "1.0.0",
  "private": true,
  "description": "CLI + Runtime for deploying Express.js to Yandex Cloud",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "ci": "pnpm lint && pnpm test && pnpm build",
    "dev": "pnpm -r --parallel dev",
    "clean": "pnpm -r exec rm -rf dist node_modules && rm -rf node_modules",
    "cli": "node packages/express-yc/dist/index.js",
    "setup": "pnpm install && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
